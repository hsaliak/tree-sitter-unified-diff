{
  "grammars": [
    {
      "name": "unified-diff",
      "camelcase": "UnifiedDiff",
      "scope": "source.diff",
      "path": ".",
      "file-types": [
        "diff",
        "patch"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for unified diff",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-unified-diff"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}