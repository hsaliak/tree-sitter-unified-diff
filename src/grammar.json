{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "unified_diff",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PREC",
            "value": 2,
            "content": {
              "type": "SYMBOL",
              "name": "file_patch"
            }
          },
          {
            "type": "SYMBOL",
            "name": "preamble_line"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          }
        ]
      }
    },
    "file_patch": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "from_file_line"
        },
        {
          "type": "STRING",
          "value": "\n"
        },
        {
          "type": "SYMBOL",
          "name": "to_file_line"
        },
        {
          "type": "STRING",
          "value": "\n"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "hunk"
          }
        }
      ]
    },
    "hunk": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "hunk_header"
        },
        {
          "type": "STRING",
          "value": "\n"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "context_line"
              },
              {
                "type": "SYMBOL",
                "name": "addition_line"
              },
              {
                "type": "SYMBOL",
                "name": "deletion_line"
              },
              {
                "type": "SYMBOL",
                "name": "note_line"
              }
            ]
          }
        }
      ]
    },
    "from_file_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "--- [^\\n]*"
        }
      }
    },
    "to_file_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "\\+\\+\\+ [^\\n]*"
        }
      }
    },
    "hunk_header": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "@@ -[0-9]+(,[0-9]+)? \\+[0-9]+(,[0-9]+)? @@[^\\n]*"
        }
      }
    },
    "context_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": " "
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            },
            {
              "type": "STRING",
              "value": "\n"
            }
          ]
        }
      }
    },
    "addition_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "+"
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            },
            {
              "type": "STRING",
              "value": "\n"
            }
          ]
        }
      }
    },
    "deletion_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "-"
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            },
            {
              "type": "STRING",
              "value": "\n"
            }
          ]
        }
      }
    },
    "note_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\\ No newline at end of file"
            },
            {
              "type": "STRING",
              "value": "\n"
            }
          ]
        }
      }
    },
    "preamble_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^\\n]+"
            },
            {
              "type": "STRING",
              "value": "\n"
            }
          ]
        }
      }
    },
    "blank_line": {
      "type": "STRING",
      "value": "\n"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
}
